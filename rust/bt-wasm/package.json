{
  "name": "bt-wasm-e2e",
  "version": "0.0.0",
  "private": true,
  "description": "Browser client for the BattleTris wasm engine (TypeScript) + its Playwright e2e tests.",
  "scripts": {
    "build:wasm": "wasm-pack build . --target web --out-dir pkg --dev",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:wasm && npm run build:ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "node --test --experimental-strip-types www/*.test.ts",
    "test:e2e": "playwright test",
    "test": "npm run build && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "typescript": "^5.6.0"
  }
}
