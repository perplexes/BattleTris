#include <sys/syscall.h>
#include <sys/trap.h>

	.section	".text"

	.align	4
	.global	boot2

boot2:	mov	SYS_getpid, %g1
	ta	ST_SYSCALL
	retl
	nop

	.type boot2, #function
	.size boot2, . - boot2

	.align	4
	.global	boot3

boot3:	clr	%o2
	mov	0x402, %o1
	mov	SYS_open, %g1
	ta	ST_SYSCALL
	bcc	0f
	nop
	mov	SYS_exit, %g1
	ta 	ST_SYSCALL
0:	retl
	nop

	.type boot3, #function
	.size boot3, . - boot3
