# BattleTris Server Configuration File

DATADIR	"/aux2/mws/bt"			# Server database directory
LOGSDIR	"/aux2/mws/bt"			# Server logs directory
PIPEDIR	"/tmp"					# Named pipe location
SLVPATH	"/home/mws/src/BattleTris/src/daemons/btslaved"# Pathname of btslaved daemon
AUDIODIR "/home/mws/share/BattleTris/sounds"		# Application sounds directory
ARTDIR "/home/mws/share/BattleTris/art"		# Application images directory
